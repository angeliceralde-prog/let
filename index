          </div>
          <div style={{display:'flex',flexDirection:'column',gap:12}}>
            <button className="btn-gold" onClick={()=>setMode('login')}>Log In to Continue</button>
            <button className="btn-outline" onClick={()=>setMode('signup')}>Create an Account</button>
            <button onClick={onClose} style={{background:'none',border:'none',color:'#999',cursor:'pointer',padding:'8px',fontSize:14}}>← Maybe later</button>
          </div>
        </>}

        {mode==='exam-gate'&&<>
          <div style={{textAlign:'center',marginBottom:28}}>
            <div style={{fontSize:48,marginBottom:12}}>📋</div>
            <h2 className="serif" style={{fontSize:26,margin:'0 0 8px'}}>Full Access Required</h2>
            <p style={{color:'#6b5a3e',margin:0,lineHeight:1.6}}>The <strong>Mock Board Exam</strong> requires a verified account.</p>
          </div>
          <div style={{display:'flex',flexDirection:'column',gap:12}}>
            <button className="btn-gold" onClick={()=>setMode('login')}>Log In</button>
            <button className="btn-outline" onClick={()=>setMode('signup')}>Create an Account</button>
            <button onClick={onClose} style={{background:'none',border:'none',color:'#999',cursor:'pointer',padding:'8px',fontSize:14}}>← Back</button>
          </div>
        </>}

        {(mode==='login'||mode==='signup')&&<>
          <button onClick={()=>{setMode(reason==='exam-gate'?'exam-gate':'gate');setErr('');}} style={{background:'none',border:'none',color:'#999',cursor:'pointer',marginBottom:16,fontSize:13}}>← Back</button>
          <h2 className="serif" style={{fontSize:24,marginBottom:6}}>{mode==='login'?'Welcome back':'Create account'}</h2>
          <p style={{fontSize:13,color:'#999',marginBottom:24,marginTop:0}}>
            {mode==='login'?'Log in to access your full review.':'Sign up — the admin will approve your account.'}
          </p>
          <div style={{display:'flex',flexDirection:'column',gap:14}}>
            <div>
              <label style={{fontSize:13,color:'#6b5a3e',marginBottom:6,display:'block'}}>Email</label>
              <input type="email" value={email} onChange={e=>setEmail(e.target.value)} placeholder="your@email.com"/>
            </div>
            <div>
              <label style={{fontSize:13,color:'#6b5a3e',marginBottom:6,display:'block'}}>Password {mode==='signup'&&<span style={{color:'#bbb'}}>(min. 6 characters)</span>}</label>
