function MockExam({onFinish}){
  const [questions]=useState(()=>buildExamQuestions());
  const [current,setCurrent]=useState(0);
  const [answers,setAnswers]=useState({});
  const [flagged,setFlagged]=useState(new Set());
  const [timeLeft,setTimeLeft]=useState(EXAM_TOTAL_MINUTES*60);
  const [showNav,setShowNav]=useState(false);
  const [showConfirm,setShowConfirm]=useState(false);
  const timerRef=useRef(null);
  const startTimeRef=useRef(Date.now());

  useEffect(()=>{
    timerRef.current=setInterval(()=>{
      setTimeLeft(t=>{if(t<=1){clearInterval(timerRef.current);doSubmit();return 0;}return t-1;});
    },1000);
    return()=>clearInterval(timerRef.current);
  },[]);

  const doSubmit=()=>{
    clearInterval(timerRef.current);
    const elapsed=Math.floor((Date.now()-startTimeRef.current)/1000);
    const results=questions.map((q,i)=>({...q,selected:answers[i]||null,correct:answers[i]===q.answer}));
    onFinish(results,elapsed);
  };

  const q=questions[current];
  const total=questions.length;
  const answeredCount=Object.keys(answers).length;
  const timerClass=timeLeft>300?'timer-normal':timeLeft>60?'timer-warning':'timer-danger';

  const navPanel=(
    <div>
      <div className="card" style={{padding:'16px 20px',marginBottom:12}}>
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
          <span style={{fontSize:13,fontWeight:600,color:'#2c1f0e'}}>Progress</span>
          <span style={{fontSize:13,color:'#999'}}>{answeredCount}/{total}</span>
        </div>
        <div className="progress-bar"><div className="progress-fill-exam" style={{width:`${Math.round(answeredCount/total*100)}%`}}/></div>
      </div>
      <div className="card" style={{padding:'16px 20px',marginBottom:12}}>
        <p style={{margin:'0 0 10px',fontSize:13,fontWeight:600,color:'#2c1f0e'}}>Question Navigator</p>
        <div className="q-grid">
          {questions.map((_,i)=>{
            let cls='q-dot';
            if(i===current)cls+=' current';
            else if(flagged.has(i)&&answers[i])cls+=' flagged answered';
            else if(flagged.has(i))cls+=' flagged';
            else if(answers[i])cls+=' answered';
            return<button key={i} className={cls} onClick={()=>{setCurrent(i);setShowNav(false)}}>{i+1}</button>;
          })}
        </div>
        <div style={{display:'flex',gap:8,flexWrap:'wrap',marginTop:12}}>
          {[{cls:'q-dot answered',label:'Answered'},{cls:'q-dot flagged',label:'Flagged'},{cls:'q-dot',label:'Unanswered'}].map(l=>(
            <div key={l.label} style={{display:'flex',alignItems:'center',gap:5}}>
              <div className={l.cls} style={{width:14,height:14,borderRadius:4,fontSize:0}}/>
              <span style={{fontSize:11,color:'#999'}}>{l.label}</span>
            </div>
          ))}
        </div>
      </div>
      <button className="btn-gold" style={{width:'100%',padding:'13px',fontSize:14}} onClick={()=>setShowConfirm(true)}>Submit Exam</button>
    </div>
  );

  return(
    <div style={{position:'relative',zIndex:1}}>
      <div style={{background:'#fff',borderBottom:'1px solid #e8e4dc',padding:'0 16px',position:'sticky',top:56,zIndex:40}}>
        <div style={{maxWidth:960,margin:'0 auto',height:52,display:'flex',alignItems:'center',gap:16,justifyContent:'space-between'}}>
          <div style={{display:'flex',alignItems:'center',gap:12}}>
            <span style={{fontSize:14,fontWeight:600,color:'#283593'}}>Mock Board Exam</span>
            <span style={{fontSize:13,color:'#999'}}>{answeredCount}/{total} answered</span>
          </div>
          <div style={{display:'flex',alignItems:'center',gap:14}}>
            <div style={{display:'flex',alignItems:'center',gap:8,background:'#f5f5f5',borderRadius:8,padding:'6px 14px'}}>
              <span style={{fontSize:14}}>⏱</span>
              <span className={timerClass}>{fmtTime(timeLeft)}</span>
            </div>
            <button className="mobile-nav-btn btn-outline" style={{padding:'6px 14px',fontSize:13}} onClick={()=>setShowNav(true)}>Navigator</button>
          </div>
