// ROOT APP
// ══════════════════════════════════════════════════════
function App(){
  const [page,setPage]=useState('home');
  const [selectedCat,setSelectedCat]=useState(null);
  const [quizQuestions,setQuizQuestions]=useState([]);
  const [examResults,setExamResults]=useState(null);
  const [examElapsed,setExamElapsed]=useState(0);
  const [user,setUser]=useState(null);
  const [hasAccess,setHasAccess]=useState(false);
  const [showLock,setShowLock]=useState(false);
  const [lockReason,setLockReason]=useState('');
  const [showExamSetup,setShowExamSetup]=useState(false);
  const [loading,setLoading]=useState(true);

  const loadAccess=async(u)=>{
    const access=await checkAccess(u.email);
    setHasAccess(!!(access&&access.status==='approved'));
  };

  useEffect(()=>{
    supabase.auth.getSession().then(async({data:{session}})=>{
      if(session?.user){setUser(session.user);await loadAccess(session.user);}
      setLoading(false);
    });
    const {data:sub}=supabase.auth.onAuthStateChange(async(event,session)=>{
      if(session?.user){setUser(session.user);await loadAccess(session.user);}
      else{setUser(null);setHasAccess(false);}
    });
    return()=>sub.subscription.unsubscribe();
  },[]);

  const handleSelectCategory=(cat)=>{
    const used=getCategoryFreeCount(cat);
    if(!user&&used>=FREE_LIMIT){setLockReason('free');setShowLock(true);return;}
    if(user&&!hasAccess){setLockReason('pending');setShowLock(true);return;}
    setSelectedCat(cat);setQuizQuestions(shuffle(questionBank[cat]));setPage('quiz');
  };

  const handleShowLock=(reason)=>{
    setLockReason(reason==='exam'?'exam-gate':'free');setShowLock(true);
  };

  const handleLoginSuccess=(u,access)=>{
    setUser(u);setHasAccess(access);setShowLock(false);
    if(access)setShowExamSetup(true);
  };

  const handleLogout=async()=>{await signOut();setUser(null);setHasAccess(false);setPage('home');};

  if(loading)return(
    <div style={{minHeight:'100vh',display:'flex',alignItems:'center',justifyContent:'center'}}>
      <div><div className="spinner" style={{width:36,height:36,margin:'0 auto 12px'}}/><p style={{color:'#999',fontSize:14,textAlign:'center'}}>Loading…</p></div>
    </div>
  );

  return(
    <div style={{position:'relative',zIndex:1}}>
      <nav style={{background:'rgba(255,255,255,.88)',backdropFilter:'blur(12px)',borderBottom:'1px solid #e8e4dc',position:'sticky',top:0,zIndex:50,padding:'0 16px'}}>
        <div style={{maxWidth:960,margin:'0 auto',height:56,display:'flex',alignItems:'center',justifyContent:'space-between'}}>
          <button onClick={()=>setPage('home')} style={{background:'none',border:'none',cursor:'pointer',display:'flex',alignItems:'center',gap:10}}>
            <div style={{width:32,height:32,borderRadius:8,background:'linear-gradient(135deg,#c9a96e,#a07840)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:16}}>🎓</div>
            <span className="serif" style={{fontSize:18,color:'#1a1208'}}>LET Review Hub</span>
          </button>
          <div style={{display:'flex',alignItems:'center',gap:10}}>
            {page==='exam'&&<span style={{fontSize:13,color:'#5c6bc0',fontWeight:600}}>📋 Mock Board Exam</span>}
            {!user&&<button className="btn-outline" style={{padding:'7px 18px',fontSize:14}} onClick={()=>handleShowLock('free')}>Log In</button>}
          </div>
        </div>
      </nav>

      {page==='home'&&<HomePage onSelectCategory={handleSelectCategory} onStartExam={()=>setShowExamSetup(true)} user={user} hasAccess={hasAccess} onLogout={handleLogout} onShowLock={handleShowLock}/>}
      {page==='quiz'&&selectedCat&&<QuizView category={selectedCat} questions={quizQuestions} freeCount={getCategoryFreeCount(selectedCat)} hasAccess={hasAccess} onBack={()=>setPage('home')} onGateHit={()=>{setLockReason('free');setShowLock(true);}}/>}
      {page==='exam'&&<MockExam onFinish={(results,elapsed)=>{setExamResults(results);setExamElapsed(elapsed);setPage('exam-results');}}/>}
      {page==='exam-results'&&examResults&&<ExamResults results={examResults} elapsed={examElapsed} onRetake={()=>{setExamResults(null);setPage('exam');}} onHome={()=>setPage('home')}/>}

      {showExamSetup&&hasAccess&&<ExamSetupModal onClose={()=>setShowExamSetup(false)} onStart={()=>{setShowExamSetup(false);setPage('exam');}}/>}
      {showLock&&<LockModal onClose={()=>setShowLock(false)} onLoginSuccess={handleLoginSuccess} reason={lockReason}/>}

      <footer style={{textAlign:'center',padding:'32px 16px',color:'#bbb',fontSize:13}}>
        <p style={{margin:0}}>© 2026 LET Review Hub · For aspiring licensed professional teachers</p>
        <p style={{margin:'6px 0 0',color:'#f5a623',fontSize:12}}>⚠️ Unauthorized distribution or reselling is prohibited.</p>
      </footer>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
