                onKeyDown={e=>e.key==='Enter'&&(mode==='login'?doLogin():doSignup())}/>
            </div>
            {err&&<div style={{background:'#ffebee',color:'#c62828',padding:'10px 14px',borderRadius:8,fontSize:13}}>{err}</div>}
            <button className="btn-gold" disabled={loading||!email||!password} onClick={mode==='login'?doLogin:doSignup}>
              {loading?<span className="spinner"/>:mode==='login'?'Log In':'Create Account'}
            </button>
            <p style={{fontSize:13,color:'#999',textAlign:'center',margin:0}}>
              {mode==='login'?"Don't have an account? ":"Already have one? "}
              <span style={{color:'#c9a96e',cursor:'pointer'}} onClick={()=>{setMode(mode==='login'?'signup':'login');setErr('');}}>
                {mode==='login'?'Sign up':'Log in'}
              </span>
            </p>
          </div>
        </>}

        {mode==='pending'&&<>
          <div style={{textAlign:'center'}}>
            <div style={{fontSize:52,marginBottom:16}}>⏳</div>
            <h2 className="serif" style={{fontSize:24,marginBottom:12}}>Account Created!</h2>
            <p style={{color:'#6b5a3e',lineHeight:1.7,marginBottom:20}}>
