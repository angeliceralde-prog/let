function ExamResults({results,elapsed,onRetake,onHome}){
  const [showReview,setShowReview]=useState(false);
  const [reviewCat,setReviewCat]=useState(null);
  const [filter,setFilter]=useState('all');
  const total=results.length;
  const correct=results.filter(r=>r.correct).length;
  const pct=Math.round(correct/total*100);
  const passed=pct>=75;
  const catStats={};
  results.forEach(r=>{
    if(!catStats[r.category])catStats[r.category]={correct:0,total:0};
    catStats[r.category].total++;
    if(r.correct)catStats[r.category].correct++;
  });
  const displayResults=filter==='wrong'?results.filter(r=>!r.correct):results;
  if(showReview){
    const catResults=reviewCat?displayResults.filter(r=>r.category===reviewCat):displayResults;
    return(
      <div style={{maxWidth:680,margin:'0 auto',padding:'0 16px 48px'}}>
        <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:24,flexWrap:'wrap'}}>
          <button onClick={()=>setShowReview(false)} style={{background:'none',border:'none',color:'#c9a96e',cursor:'pointer',fontSize:14,padding:0}}>← Back to results</button>
          <div style={{display:'flex',gap:8,marginLeft:'auto'}}>
            <button onClick={()=>setFilter('all')} style={{padding:'6px 14px',borderRadius:8,border:`1.5px solid ${filter==='all'?'#5c6bc0':'#e0d9cc'}`,background:filter==='all'?'#e8eaf6':'transparent',fontFamily:'DM Sans',fontSize:13,cursor:'pointer',fontWeight:500}}>All</button>
            <button onClick={()=>setFilter('wrong')} style={{padding:'6px 14px',borderRadius:8,border:`1.5px solid ${filter==='wrong'?'#ef5350':'#e0d9cc'}`,background:filter==='wrong'?'#ffebee':'transparent',fontFamily:'DM Sans',fontSize:13,cursor:'pointer',fontWeight:500}}>Wrong only</button>
          </div>
        </div>
        <div style={{display:'flex',gap:8,flexWrap:'wrap',marginBottom:20}}>
          <button onClick={()=>setReviewCat(null)} style={{padding:'6px 14px',borderRadius:20,border:`1.5px solid ${!reviewCat?'#5c6bc0':'#e0d9cc'}`,background:!reviewCat?'#e8eaf6':'transparent',fontFamily:'DM Sans',fontSize:12,cursor:'pointer',fontWeight:500}}>All subjects</button>
          {Object.keys(catStats).map(c=>(
            <button key={c} onClick={()=>setReviewCat(c)} style={{padding:'6px 14px',borderRadius:20,border:`1.5px solid ${reviewCat===c?categoryMeta[c].color:'#e0d9cc'}`,background:reviewCat===c?categoryMeta[c].bg:'transparent',fontFamily:'DM Sans',fontSize:12,cursor:'pointer',fontWeight:500,color:reviewCat===c?categoryMeta[c].color:'#6b5a3e'}}>
              {categoryMeta[c].icon} {c.replace('Major (','').replace(')','').replace(' Education','')}
            </button>
          ))}
        </div>
        {catResults.map((r,i)=>(
          <div key={i} className="card" style={{padding:'20px 24px',marginBottom:12}}>
            <div style={{display:'flex',alignItems:'flex-start',gap:10,marginBottom:10}}>
              <span style={{fontSize:18,flexShrink:0}}>{r.correct?'✅':'❌'}</span>
              <div style={{flex:1}}>
                <div style={{display:'flex',gap:8,marginBottom:6,flexWrap:'wrap'}}>
                  <span className="tag" style={{background:categoryMeta[r.category].bg,color:categoryMeta[r.category].color,fontSize:11}}>{categoryMeta[r.category].icon} {r.category}</span>
                  <span style={{fontSize:11,color:'#bbb'}}>Item {r.examNum}</span>
                </div>
                <p style={{margin:0,fontWeight:500,lineHeight:1.5,fontSize:15}}>{r.q}</p>
              </div>
            </div>
            {!r.correct&&r.selected&&<p style={{margin:'0 0 6px',fontSize:13,color:'#c62828'}}>Your answer: {r.selected}</p>}
            {!r.selected&&<p style={{margin:'0 0 6px',fontSize:13,color:'#999',fontStyle:'italic'}}>Not answered</p>}
            <p style={{margin:'0 0 10px',fontSize:13,color:'#2e7d32',fontWeight:500}}>✓ Correct: {r.answer}</p>
            <div style={{background:'#fdf5e8',borderRadius:8,padding:'10px 14px'}}>
              <p style={{margin:0,fontSize:13,color:'#6b5a3e',lineHeight:1.65}}>💡 {r.rationale}</p>
            </div>
          </div>
        ))}
      </div>
    );
  }
  return(
    <div className="fade-in" style={{maxWidth:680,margin:'0 auto',padding:'0 16px 60px'}}>
      <div className="card" style={{padding:'40px 36px',textAlign:'center',marginBottom:24,background:passed?'linear-gradient(135deg,#e8f5e9,#f1f8e9)':'linear-gradient(135deg,#fff8e1,#fafafa)'}}>
        <div style={{fontSize:64,marginBottom:12}}>{passed?'🏆':pct>=60?'📚':'💪'}</div>
        <h2 className="serif" style={{fontSize:38,margin:'0 0 4px',color:passed?'#1b5e20':'#2c1f0e'}}>{passed?'PASSED!':'Not Yet'}</h2>
        <p style={{color:'#999',marginBottom:28,fontSize:15}}>Mock Board Exam · {total} items · {fmtTime(elapsed)}</p>
        <div style={{display:'flex',justifyContent:'center',gap:40,marginBottom:16}}>
          <div><div style={{fontSize:40,fontWeight:700,color:'#c9a96e'}}>{correct}/{total}</div><div style={{fontSize:13,color:'#999'}}>Correct</div></div>
          <div><div style={{fontSize:40,fontWeight:700,color:passed?'#2e7d32':pct>=60?'#e65100':'#c62828'}}>{pct}%</div><div style={{fontSize:13,color:'#999'}}>Score</div></div>
