      </div>
      {showNav&&(
        <div className="modal-overlay" onClick={()=>setShowNav(false)}>
          <div className="modal-box fade-in" onClick={e=>e.stopPropagation()} style={{maxWidth:340,maxHeight:'80vh',overflowY:'auto'}}>
            <button onClick={()=>setShowNav(false)} style={{background:'none',border:'none',color:'#999',cursor:'pointer',marginBottom:12,fontSize:13}}>← Close</button>
            {navPanel}
          </div>
        </div>
      )}
      {showConfirm&&(
        <div className="modal-overlay" onClick={()=>setShowConfirm(false)}>
          <div className="modal-box fade-in" onClick={e=>e.stopPropagation()}>
            <div style={{textAlign:'center',marginBottom:24}}>
              <div style={{fontSize:44,marginBottom:12}}>📋</div>
              <h2 className="serif" style={{fontSize:24,margin:'0 0 8px'}}>Submit Exam?</h2>
              <p style={{color:'#6b5a3e',lineHeight:1.6,margin:0}}>
                You have answered <strong>{answeredCount} of {total}</strong> questions.
                {answeredCount<total&&<><br/><span style={{color:'#e65100',fontWeight:600}}>{total-answeredCount} unanswered</span> items will be marked wrong.</>}
              </p>
            </div>
            <div style={{display:'flex',gap:12}}>
              <button className="btn-outline" style={{flex:1}} onClick={()=>setShowConfirm(false)}>Keep Going</button>
              <button className="btn-gold" style={{flex:1}} onClick={doSubmit}>Submit Now</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

