// ── Auth helpers ─────────────────────────────────────
async function signIn(e,p){return supabase.auth.signInWithPassword({email:e,password:p})}
async function signOut(){await supabase.auth.signOut()}

async function signUp(email, password) {
  // 1. Create auth account
  const { data, error } = await supabase.auth.signUp({ email, password });
  if (error) return { error };

  // 2. Manually insert into approved_users with 'pending'
  //    (in case trigger hasn't fired yet or email not confirmed)
  await supabase.from('approved_users').upsert(
    { email, status: 'pending' },
    { onConflict: 'email', ignoreDuplicates: true }
  );

  return { data };
}

async function checkAccess(email){
  const {data}=await supabase.from('approved_users').select('email,status').eq('email',email).maybeSingle();
  return data;
}

// ── Helpers ──────────────────────────────────────────
function shuffle(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}
function getFreeUsage(){try{return JSON.parse(localStorage.getItem('let_free_usage')||'{}')}catch{return{}}}
function setFreeUsage(d){localStorage.setItem('let_free_usage',JSON.stringify(d))}
function getCategoryFreeCount(c){return getFreeUsage()[c]||0}
function incrementFreeCount(c){const u=getFreeUsage();u[c]=(u[c]||0)+1;setFreeUsage(u)}
function fmtTime(s){
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;
  if(h>0)return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

function buildExamQuestions(){
  const all=[];let qNum=1;
  Object.entries(EXAM_CONFIG).forEach(([cat,cfg])=>{
    const pool=shuffle(questionBank[cat]);
    pool.slice(0,cfg.count).forEach(q=>{all.push({...q,category:cat,examNum:qNum++})});
  });
  return all;
}

