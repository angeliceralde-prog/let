// LOCK MODAL — fixed sign-up flow
// ══════════════════════════════════════════════════════
function LockModal({onClose,onLoginSuccess,reason}){
  const [mode,setMode]=useState(reason==='pending'?'pending':reason==='exam-gate'?'exam-gate':'gate');
  const [email,setEmail]=useState('');
  const [password,setPassword]=useState('');
  const [loading,setLoading]=useState(false);
  const [err,setErr]=useState('');
  const [signupEmail,setSignupEmail]=useState('');

  const doLogin=async()=>{
    if(!email||!password)return;
    setLoading(true);setErr('');
    const {data,error}=await signIn(email,password);
    if(error){
      // Friendly error messages
      let msg=error.message;
      if(msg.includes('Invalid login credentials'))msg='Incorrect email or password. Please try again.';
      if(msg.includes('Email not confirmed'))msg='Please confirm your email first, or contact the admin.';
      setErr(msg);setLoading(false);return;
    }
    const access=await checkAccess(data.user.email);
    setLoading(false);
    if(access&&access.status==='approved'){onLoginSuccess(data.user,true);}
    else{setMode('pending');setSignupEmail(data.user.email);}
  };

  const doSignup=async()=>{
    if(!email||!password)return;
    if(password.length<6){setErr('Password must be at least 6 characters.');return;}
    setLoading(true);setErr('');
    const {data,error}=await signUp(email,password);
    if(error){
      let msg=error.message;
      if(msg.includes('already registered')||msg.includes('already been registered'))
        msg='This email is already registered. Please log in instead.';
      setErr(msg);setLoading(false);return;
    }
    setSignupEmail(email);
    setLoading(false);
    setMode('pending');
  };

  return(
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal-box fade-in" onClick={e=>e.stopPropagation()}>

        {mode==='gate'&&<>
          <div style={{textAlign:'center',marginBottom:28}}>
