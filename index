// QUIZ VIEW
// ══════════════════════════════════════════════════════
function QuizView({category,questions,freeCount,hasAccess,onBack,onGateHit}){
  const [current,setCurrent]=useState(0);
  const [selected,setSelected]=useState(null);
  const [answered,setAnswered]=useState(false);
  const [score,setScore]=useState(0);
  const [done,setDone]=useState(false);
  const [history,setHistory]=useState([]);
  const usedRef=useRef(freeCount);
  const q=questions[current];
  const total=questions.length;
  const pct=Math.round((score/history.length)*100)||0;
  const meta=categoryMeta[category];

  const handleChoice=(choice)=>{
    if(answered)return;
    if(!hasAccess){
      if(usedRef.current>=FREE_LIMIT){onGateHit();return;}
      incrementFreeCount(category);usedRef.current++;
    }
    setSelected(choice);setAnswered(true);
    if(choice===q.answer)setScore(s=>s+1);
    setHistory(h=>[...h,{q:q.q,answer:q.answer,selected:choice,correct:choice===q.answer,rationale:q.rationale}]);
  };
  const next=()=>{
    if(current<total-1){setCurrent(c=>c+1);setSelected(null);setAnswered(false);}
    else setDone(true);
  };

  if(done)return(
    <div className="fade-in" style={{maxWidth:640,margin:'0 auto',padding:'0 16px 48px'}}>
      <button onClick={onBack} style={{background:'none',border:'none',color:'#c9a96e',cursor:'pointer',fontSize:14,marginBottom:24,padding:0}}>← Back to topics</button>
      <div className="card" style={{padding:'40px 36px',textAlign:'center',marginBottom:24}}>
        <div style={{fontSize:56,marginBottom:12}}>{pct>=80?'🏆':pct>=60?'📖':'💪'}</div>
        <h2 className="serif" style={{fontSize:32,marginBottom:4}}>{pct>=80?'Excellent!':pct>=60?'Good effort!':'Keep practicing!'}</h2>
        <p style={{color:'#999',marginBottom:28}}>{category}</p>
        <div style={{display:'flex',justifyContent:'center',gap:40,marginBottom:28}}>
          <div><div style={{fontSize:36,fontWeight:600,color:'#c9a96e'}}>{score}/{history.length}</div><div style={{fontSize:13,color:'#999'}}>Correct</div></div>
          <div><div style={{fontSize:36,fontWeight:700,color:pct>=80?'#2e7d32':pct>=60?'#e65100':'#c62828'}}>{pct}%</div><div style={{fontSize:13,color:'#999'}}>Score</div></div>
        </div>
        <div style={{display:'flex',gap:12,justifyContent:'center',flexWrap:'wrap'}}>
          <button className="btn-gold" onClick={()=>{setCurrent(0);setSelected(null);setAnswered(false);setScore(0);setDone(false);setHistory([]);usedRef.current=getCategoryFreeCount(category);}}>Retake Quiz</button>
          <button className="btn-outline" onClick={onBack}>Back to Topics</button>
        </div>
      </div>
      <h3 className="serif" style={{fontSize:20,marginBottom:16}}>Review your answers</h3>
      {history.map((h,i)=>(
        <div key={i} className="card" style={{padding:'20px 24px',marginBottom:12}}>
          <div style={{display:'flex',alignItems:'flex-start',gap:12,marginBottom:12}}>
            <span style={{fontSize:18}}>{h.correct?'✅':'❌'}</span>
            <p style={{margin:0,fontWeight:500,lineHeight:1.5}}>{h.q}</p>
          </div>
          {!h.correct&&<p style={{margin:'0 0 8px',fontSize:14,color:'#c62828'}}>Your answer: {h.selected}</p>}
          <p style={{margin:'0 0 8px',fontSize:14,color:'#2e7d32'}}>Correct: {h.answer}</p>
          <div style={{background:'#fdf5e8',borderRadius:8,padding:'10px 14px'}}>
            <p style={{margin:0,fontSize:13,color:'#6b5a3e',lineHeight:1.6}}>💡 {h.rationale}</p>
          </div>
        </div>
      ))}
    </div>
  );

  return(
    <div className="fade-in" style={{maxWidth:640,margin:'0 auto',padding:'0 16px 48px'}}>
      <button onClick={onBack} style={{background:'none',border:'none',color:'#c9a96e',cursor:'pointer',fontSize:14,marginBottom:20,padding:0}}>← Back to topics</button>
      <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:20}}>
        <div style={{width:44,height:44,borderRadius:12,background:meta.bg,display:'flex',alignItems:'center',justifyContent:'center',fontSize:22}}>{meta.icon}</div>
        <div style={{flex:1}}>
          <p style={{margin:0,fontWeight:600,fontSize:15,color:'#2c1f0e'}}>{category}</p>
          <p style={{margin:0,fontSize:13,color:'#999'}}>Question {current+1} of {total}</p>
        </div>
        <p style={{margin:0,fontWeight:600,color:'#c9a96e',fontSize:15}}>{score} pts</p>
      </div>
      <div className="progress-bar" style={{marginBottom:28}}><div className="progress-fill" style={{width:`${Math.round(current/total*100)}%`}}/></div>
      <div className="card" style={{padding:'28px 28px 24px',marginBottom:20}}>
        <p style={{margin:'0 0 24px',fontSize:17,fontWeight:500,lineHeight:1.65,color:'#1a1208'}}>{q.q}</p>
        <div style={{display:'flex',flexDirection:'column',gap:10}}>
          {q.choices.map((c,i)=>{
            let cls='choice-btn';
            if(answered){if(c===q.answer)cls+=selected===c?' correct':' reveal';else if(c===selected)cls+=' wrong';}
            return(
              <button key={i} className={cls} onClick={()=>handleChoice(c)} disabled={answered}>
                <span className="choice-letter">{String.fromCharCode(65+i)}</span>
                <span style={{flex:1,lineHeight:1.45}}>{c}</span>
                {answered&&c===q.answer&&<span style={{fontSize:18}}>✓</span>}
                {answered&&c===selected&&c!==q.answer&&<span style={{fontSize:18}}>✗</span>}
              </button>
            );
          })}
        </div>
        {answered&&(
          <div className="fade-in" style={{marginTop:20,background:'#fdf5e8',border:'1px solid #e8d9b8',borderRadius:12,padding:'14px 18px'}}>
            <p style={{margin:0,fontSize:14,color:'#6b5a3e',lineHeight:1.65}}><strong>💡 Rationale:</strong> {q.rationale}</p>
          </div>
        )}
      </div>
      {answered&&<div style={{textAlign:'right'}}><button className="btn-gold" onClick={next}>{current<total-1?'Next Question →':'See Results →'}</button></div>}
      {!hasAccess&&<div style={{textAlign:'center',marginTop:16}}><p style={{fontSize:13,color:'#999'}}>{Math.max(0,FREE_LIMIT-usedRef.current)} free question{FREE_LIMIT-usedRef.current!==1?'s':''} remaining</p></div>}
    </div>
  );
}

